#!/bin/sh
set -eu

find_invoked_script_path() {
  case "$1" in
    */*)
      printf '%s\n' "$1"
      ;;
    *)
      command -v "$1" 2>/dev/null || printf '%s\n' "$1"
      ;;
  esac
}

resolve_script_path() {
  current=$1
  case "$current" in
    /*) ;;
    *)
      current="$(pwd -P)/$current"
      ;;
  esac

  while [ -L "$current" ]; do
    link_target=$(readlink "$current")
    case "$link_target" in
      /*)
        current=$link_target
        ;;
      *)
        current_dir=$(CDPATH= cd -- "$(dirname -- "$current")" && pwd -P)
        current="$current_dir/$link_target"
        ;;
    esac
  done

  current_dir=$(CDPATH= cd -- "$(dirname -- "$current")" && pwd -P)
  printf '%s/%s\n' "$current_dir" "${current##*/}"
}

SCRIPT_PATH=$(find_invoked_script_path "$0")
CLI_NAME=${DOTFILES_CLI_NAME:-$SCRIPT_PATH}
REPO_ROOT=${DOTFILES_REPO_ROOT:-}
if [ -z "$REPO_ROOT" ]; then
  RESOLVED_SCRIPT_PATH=$(resolve_script_path "$SCRIPT_PATH")
  SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$RESOLVED_SCRIPT_PATH")" && pwd -P)
  REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd -P)
fi

# shellcheck source=/dev/null
. "$REPO_ROOT/scripts/sh/cli-lib.sh"

usage() {
  printf '%bUsage:%b %s [global-options] <command> [command-args]\n' "$CLR_BOLD" "$CLR_RESET" "$CLI_NAME"
  printf '\n'
  printf '%bGlobal options:%b\n' "$CLR_CYAN" "$CLR_RESET"
  printf '  --repo-root <path>         Override repo root detection\n'
  printf '  --dry-run                  Print actions without changing anything\n'
  printf '  --yes, -y                  Approve prompts in delegated commands\n'
  printf '  --non-interactive          Fail instead of prompting in delegated commands\n'
  printf '  --skip-apply               Skip the apply phase for install/update\n'
  printf '  --skip-tools               Skip default agent-tool installation for install/update\n'
  printf '  --help, -h                 Show this help\n'
  printf '\n'
  printf '%bCommands:%b\n' "$CLR_CYAN" "$CLR_RESET"
  printf '  help                       Show this help\n'
  printf '  bootstrap                  Run bootstrap/install.sh using this repo as the source\n'
  printf '  install                    Apply configs from this checkout if the apply engine exists\n'
  printf '  apply                      Invoke scripts/dotfiles.py apply\n'
  printf '  update                     sync to origin/main (or $DOTFILES_BRANCH), then run install\n'
  printf '  packages                   Install default/opt-in package sets via native package managers\n'
  printf '  tools                      Inspect or install external agent tools such as RTK\n'
  printf '\n'
  printf 'See "%s update --help" for update-specific options such as --fast.\n' "$CLI_NAME"
}

update_usage() {
  cat <<USAGE
Usage: $CLI_NAME update [update-options] [install-options]

Sync this checkout to the latest state of a git remote branch, then run the
normal install/apply flow for the updated repo.

Update options:
  --remote <name>            Git remote to sync from (default: origin)
  --branch <name>            Git branch to sync from (default: \$DOTFILES_BRANCH or main)
  --fast                     Skip default agent-tool installation after syncing
  --no-stash                 Fail instead of auto-stashing local checkout changes
  --help, -h                 Show this help

Auto-stashed checkout changes stay in git stash for manual review/restore.

Put update-specific options before any forwarded install/apply options, e.g.:
  $CLI_NAME update --fast --profile linux-desktop
USAGE
}

DOTFILES_DRY_RUN=${DOTFILES_DRY_RUN:-0}
DOTFILES_YES=${DOTFILES_YES:-0}
DOTFILES_NONINTERACTIVE=${DOTFILES_NONINTERACTIVE:-0}
DOTFILES_SKIP_APPLY=${DOTFILES_SKIP_APPLY:-0}
DOTFILES_SKIP_TOOLS=${DOTFILES_SKIP_TOOLS:-0}
DOTFILES_CHECKOUT_ALREADY_UPDATED=${DOTFILES_CHECKOUT_ALREADY_UPDATED:-0}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --repo-root)
      [ "$#" -ge 2 ] || dotfiles_die "--repo-root requires a value"
      REPO_ROOT=$2
      shift 2
      ;;
    --dry-run)
      DOTFILES_DRY_RUN=1
      shift
      ;;
    --yes|-y)
      DOTFILES_YES=1
      shift
      ;;
    --non-interactive)
      DOTFILES_NONINTERACTIVE=1
      shift
      ;;
    --skip-apply)
      DOTFILES_SKIP_APPLY=1
      shift
      ;;
    --skip-tools)
      DOTFILES_SKIP_TOOLS=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      dotfiles_die "unknown option: $1"
      ;;
    *)
      break
      ;;
  esac
done

command=${1:-help}
if [ "$#" -gt 0 ]; then
  shift
fi

export DOTFILES_DRY_RUN DOTFILES_YES DOTFILES_NONINTERACTIVE DOTFILES_SKIP_APPLY DOTFILES_SKIP_TOOLS DOTFILES_CHECKOUT_ALREADY_UPDATED DOTFILES_REPO_ROOT=$REPO_ROOT

load_packages_support() {
  package_lib="$REPO_ROOT/scripts/sh/packages.sh"
  [ -f "$package_lib" ] || dotfiles_die "package support not found at $package_lib"
  # shellcheck source=/dev/null
  . "$package_lib"
}

load_tools_support() {
  tools_lib="$REPO_ROOT/scripts/sh/tools.sh"
  [ -f "$tools_lib" ] || dotfiles_die "tool support not found at $tools_lib"
  # shellcheck source=/dev/null
  . "$tools_lib"
}

run_install() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --skip-apply)
        DOTFILES_SKIP_APPLY=1
        shift
        ;;
      --skip-tools|--fast)
        DOTFILES_SKIP_TOOLS=1
        shift
        ;;
      --)
        shift
        break
        ;;
      *)
        break
        ;;
    esac
  done

  export DOTFILES_SKIP_APPLY DOTFILES_SKIP_TOOLS

  # Show banner on install (skip if already shown by run_update).
  if [ "${_dotfiles_banner_shown:-0}" != "1" ]; then
    # shellcheck source=/dev/null
    . "$REPO_ROOT/scripts/sh/banner.sh"
    dotfiles_banner
  fi

  _install_ok=0
  _install_skip=0
  _install_fail=0

  if _dotfiles_is_truthy "$DOTFILES_SKIP_APPLY"; then
    dotfiles_skip "apply step (--skip-apply)"
    _install_skip=$(( _install_skip + 1 ))
  else
    dotfiles_step "Applying configs"
    if dotfiles_invoke_apply_engine "$REPO_ROOT" apply "$@"; then
      dotfiles_ok "Configs applied"
      _install_ok=$(( _install_ok + 1 ))
    else
      exit_code=$?
    fi
    if [ "${exit_code:-0}" -eq 2 ]; then
      dotfiles_skip "apply engine not found; checkout/bootstrap completed without applying configs"
      _install_skip=$(( _install_skip + 1 ))
    elif [ "${exit_code:-0}" -ne 0 ]; then
      dotfiles_fail "Config apply failed (exit $exit_code)"
      _install_fail=$(( _install_fail + 1 ))
      return "${exit_code:-1}"
    fi

    dotfiles_setup_git_config_local || true
  fi

  if _dotfiles_is_truthy "$DOTFILES_SKIP_TOOLS"; then
    dotfiles_skip "default agent tools (--skip-tools)"
    _install_skip=$(( _install_skip + 1 ))
  else
    dotfiles_step "Installing default tools"
    if load_tools_support && dotfiles_install_default_tools; then
      dotfiles_ok "Default tools installed"
      _install_ok=$(( _install_ok + 1 ))
    else
      dotfiles_fail "Default tools installation failed"
      _install_fail=$(( _install_fail + 1 ))
    fi
  fi

  # Summary line.
  dotfiles_header "Install complete"
  if [ -n "$CLR_GREEN" ]; then
    printf '%b  ✓ %d applied%b · %b⚠ %d skipped%b · %b✗ %d failed%b\n' \
      "$CLR_GREEN" "$_install_ok" "$CLR_RESET" \
      "$CLR_YELLOW" "$_install_skip" "$CLR_RESET" \
      "$CLR_RED" "$_install_fail" "$CLR_RESET"
  else
    printf '  ok %d applied · WARN %d skipped · FAIL %d failed\n' \
      "$_install_ok" "$_install_skip" "$_install_fail"
  fi
}

dotfiles_update_checkout() {
  update_remote=$1
  update_branch=$2
  update_autostash=$3

  before_head=$(git -C "$REPO_ROOT" rev-parse --verify HEAD 2>/dev/null || true)
  status=$(git -C "$REPO_ROOT" status --porcelain --untracked-files=all 2>/dev/null || true)
  stash_name=
  backup_branch=

  if [ -n "$status" ]; then
    if ! _dotfiles_is_truthy "$update_autostash"; then
      dotfiles_die "checkout has local changes; commit or stash them first, or re-run without --no-stash"
    fi

    stash_name="dotfiles-update-$(date -u +%Y%m%dT%H%M%SZ)"
    if _dotfiles_is_truthy "$DOTFILES_DRY_RUN"; then
      dotfiles_info "Would stash local checkout changes as $stash_name"
    else
      dotfiles_info "Stashing local checkout changes as $stash_name"
    fi
    dotfiles_run git -C "$REPO_ROOT" stash push --include-untracked --message "$stash_name"
  fi

  dotfiles_run git -C "$REPO_ROOT" fetch --prune "$update_remote" "$update_branch"

  if git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$update_branch"; then
    local_branch_ref="refs/heads/$update_branch"
    local_only_commits=$(git -C "$REPO_ROOT" rev-list --count "$update_remote/$update_branch..$local_branch_ref" 2>/dev/null || printf '%s' 0)
    if [ "${local_only_commits:-0}" -gt 0 ]; then
      backup_branch="dotfiles-update-backup-$update_branch-$(date -u +%Y%m%dT%H%M%SZ)"
      dotfiles_info "Preserving local $update_branch commits in $backup_branch before syncing to $update_remote/$update_branch"
      dotfiles_run git -C "$REPO_ROOT" branch "$backup_branch" "$local_branch_ref"
    fi
  fi

  current_branch=$(git -C "$REPO_ROOT" symbolic-ref --quiet --short HEAD 2>/dev/null || true)
  if [ "$current_branch" != "$update_branch" ]; then
    if [ -n "$current_branch" ]; then
      dotfiles_info "Switching checkout from $current_branch to $update_branch"
    else
      dotfiles_info "Checking out $update_branch"
    fi

    if git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$update_branch"; then
      dotfiles_run git -C "$REPO_ROOT" checkout "$update_branch"
    else
      dotfiles_run git -C "$REPO_ROOT" checkout -B "$update_branch" "$update_remote/$update_branch"
    fi
  fi

  dotfiles_run git -C "$REPO_ROOT" reset --hard "$update_remote/$update_branch"

  if _dotfiles_is_truthy "$DOTFILES_DRY_RUN"; then
    return 0
  fi

  after_head=$(git -C "$REPO_ROOT" rev-parse --verify HEAD 2>/dev/null || true)
  if [ -n "$before_head" ] && [ -n "$after_head" ] && [ "$before_head" != "$after_head" ]; then
    dotfiles_info "Updated checkout to $update_remote/$update_branch"
    git -C "$REPO_ROOT" log --oneline --no-decorate "$before_head..$after_head" || true
  else
    dotfiles_info "Checkout already matches $update_remote/$update_branch"
  fi

  if [ -n "$stash_name" ]; then
    dotfiles_warn "Local checkout changes were stashed as $stash_name"
  fi
  if [ -n "$backup_branch" ]; then
    dotfiles_warn "Local $update_branch commits were preserved in $backup_branch before syncing"
  fi
}

run_update() {
  update_remote=${DOTFILES_UPDATE_REMOTE:-origin}
  update_branch=${DOTFILES_UPDATE_BRANCH:-${DOTFILES_BRANCH:-main}}
  update_autostash=1
  update_fast=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --remote)
        [ "$#" -ge 2 ] || dotfiles_die "--remote requires a value"
        update_remote=$2
        shift 2
        ;;
      --branch)
        [ "$#" -ge 2 ] || dotfiles_die "--branch requires a value"
        update_branch=$2
        shift 2
        ;;
      --fast)
        update_fast=1
        shift
        ;;
      --no-stash)
        update_autostash=0
        shift
        ;;
      --help|-h)
        update_usage
        return 0
        ;;
      --)
        shift
        break
        ;;
      *)
        break
        ;;
    esac
  done

  # Validate branch name contains only safe characters.
  case "$update_branch" in
    *[!a-zA-Z0-9/_.-]*)
      dotfiles_die "invalid branch name: $update_branch"
      ;;
  esac

  if _dotfiles_is_truthy "$update_fast" && ! _dotfiles_is_truthy "$DOTFILES_SKIP_TOOLS"; then
    DOTFILES_SKIP_TOOLS=1
    export DOTFILES_SKIP_TOOLS
    dotfiles_info "Fast update requested; skipping default agent tools"
  fi

  # Show banner on update.
  # shellcheck source=/dev/null
  . "$REPO_ROOT/scripts/sh/banner.sh"
  dotfiles_banner
  _dotfiles_banner_shown=1

  if _dotfiles_is_truthy "$DOTFILES_CHECKOUT_ALREADY_UPDATED"; then
    dotfiles_skip "git sync (checkout already refreshed by bootstrap)"
  else
    dotfiles_step "Syncing checkout to $update_remote/$update_branch"
    dotfiles_update_checkout "$update_remote" "$update_branch" "$update_autostash"
    dotfiles_ok "Checkout synced"
  fi

  run_install "$@"
}

case "$command" in
  help)
    usage
    ;;
  bootstrap)
    exec "$REPO_ROOT/bootstrap/install.sh" --repo "$REPO_ROOT" "$@"
    ;;
  install)
    run_install "$@"
    ;;
  apply)
    if dotfiles_invoke_apply_engine "$REPO_ROOT" apply "$@"; then
      exit 0
    else
      exit_code=$?
    fi
    if [ "$exit_code" -eq 2 ]; then
      dotfiles_die "apply engine not found at $REPO_ROOT/scripts/dotfiles.py"
    fi
    exit "$exit_code"
    ;;
  update)
    dotfiles_has_cmd git || dotfiles_die "git is required for update"
    run_update "$@"
    ;;
  packages)
    load_packages_support
    dotfiles_packages_main "$@"
    ;;
  tools)
    load_tools_support
    dotfiles_tools_main "$@"
    ;;
  *)
    dotfiles_die "unknown command: $command"
    ;;
esac
